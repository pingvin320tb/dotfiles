max-history=5
markup=1
actions=1
history=1
default-timeout=3000
sort=+time

# [ BINDING OPTIONS ]
on-button-left=invoke-default-action
on-button-middle=dismiss-group
on-button-right=dismiss
on-touch=invoke-default-action

# [ STYLE OPTIONS ]
font= JetBrainsMono Nerd Font 12
background-color=#282828
text-color=#EBDBB2

width=320
height=240

margin=10
outer-margin=0
padding=16

border-color=#83A598
border-size=2
border-radius=10

icons=1
max-icon-size=48
icon-location=left

format= <b>%s</b>\n%b
text-alignment=left
max-visible=5
layer=overlay
anchor=top-right

